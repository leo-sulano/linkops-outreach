generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prospect {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  websiteCategory  String?
  status           String   @default("OUTREACH_SENT")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
